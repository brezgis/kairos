# Kairos environment configuration.
# Copy this file to .env and fill in the values:  cp .env.example .env
# .env is gitignored — never commit it (this repo is public).

# --- Oura OAuth2 -----------------------------------------------------------
# From your Oura app at https://cloud.ouraring.com (My Applications).
OURA_CLIENT_ID=your_client_id_here
OURA_CLIENT_SECRET=your_client_secret_here

# Must match a Redirect URI registered on the Oura app EXACTLY (scheme, host,
# port, path). If Oura rejected plain http, use http://127.0.0.1:8080/callback.
OURA_REDIRECT_URI=http://localhost:8080/callback

# Optional: bind the local callback server to a different host:port than the
# redirect URI above (the redirect_uri sent to Oura is unchanged). Useful when
# the redirect port is taken, or when you reach this machine over an SSH tunnel
# like  ssh -L 8080:localhost:8742  (then set this to 127.0.0.1:8742).
# OURA_CALLBACK_BIND=127.0.0.1:8742

# Space-separated scopes to request. Stress and heart-health (cardiovascular
# age) data are served under the "daily" scope, so this set covers everything.
OURA_SCOPES=personal daily heartrate workout tag session spo2 heart_health stress

# --- Filled in automatically by scripts/oura_auth.py -----------------------
# Do not edit these by hand; running the auth script writes them.
OURA_ACCESS_TOKEN=
OURA_REFRESH_TOKEN=
OURA_ACCESS_TOKEN_EXPIRES_AT=

# --- Location (for weather; defaults to New York, NY) ---------------
KAIROS_LAT=40.71
KAIROS_LON=-74.01
KAIROS_TZ=America/New_York
KAIROS_LOCATION=New York, NY

# --- Spotify (optional) ----------------------------------------------------
# Kairos uses its OWN Spotify credentials here. You can paste the same
# client id/secret as an existing app to reuse it, or register a new one.
SPOTIFY_CLIENT_ID=
SPOTIFY_CLIENT_SECRET=
SPOTIFY_REDIRECT_URI=http://localhost:8888/callback
